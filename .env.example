# Copie ce fichier en `.env` pour le développement local (facultatif).
# En production, aucune variable n'est nécessaire : l'app et l'API vivent sur
# le même domaine (etiquette.estim.pro) et l'app appelle « /api/ ».

# Base de l'API utilisée par le front. Défaut : /api/ (même origine).
# VITE_API_BASE=/api/

# Développement local du front (npm run dev) contre un backend PHP lancé à part.
# 1) Démarrer l'API :  LETIQUETTE_DEBUG=1 php -S 127.0.0.1:8099 -t .
# 2) Lancer le front :  VITE_API_PROXY=http://127.0.0.1:8099 npm run dev
# (Vite renvoie alors /api vers le serveur PHP — pas de souci de CORS.)
# VITE_API_PROXY=http://127.0.0.1:8099
